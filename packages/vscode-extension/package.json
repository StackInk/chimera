{
  "name": "chimera-vscode",
  "displayName": "Chimera",
  "description": "Chimera Framework - Project state dashboard & Kanban board",
  "version": "0.1.0",
  "publisher": "chimera-dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.chimera/state.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chimera",
          "title": "Chimera",
          "icon": "$(layers)"
        }
      ]
    },
    "views": {
      "chimera": [
        {
          "type": "webview",
          "id": "chimera.kanbanView",
          "name": "Kanban Board"
        },
        {
          "id": "chimera.knowledgeView",
          "name": "Knowledge"
        },
        {
          "id": "chimera.constitutionView",
          "name": "Constitution"
        }
      ]
    },
    "commands": [
      {
        "command": "chimera.refresh",
        "title": "Chimera: Refresh Views",
        "icon": "$(refresh)"
      },
      {
        "command": "chimera.openState",
        "title": "Chimera: Open State File"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "chimera.refresh",
          "when": "view =~ /chimera\\./",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "package": "vsce package",
    "test": "echo 'VS Code extension tests require vscode test runner'"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StackInk/chimera.git"
  }
}
